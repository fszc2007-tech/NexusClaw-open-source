APP_NAME=nexusclaw-api
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=nexusclaw
MYSQL_PASSWORD=
MYSQL_DB=nexusclaw
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
FILE_STORAGE_ROOT=storage/uploads
ELASTICSEARCH_URL=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=nexusclaw_knowledge
VECTOR_SEARCH_URL=
VECTOR_UPSERT_URL=
VECTOR_DELETE_URL=
RERANK_URL=
RERANK_PROTECT_RAW_TOP1=true
RERANK_PROTECT_MIN_SCORE=0.6
RERANK_PROTECT_MIN_MARGIN=0.08
RERANK_PROTECT_SCORE_EPSILON=0.0001
# 可选：本地 rag 服务与模型接入
# VECTOR_SEARCH_URL=http://127.0.0.1:8101/vector/search
# VECTOR_UPSERT_URL=http://127.0.0.1:8101/vector/upsert
# VECTOR_DELETE_URL=http://127.0.0.1:8101/vector/delete
# RERANK_URL=http://127.0.0.1:8101/rerank
# 更稳的本机启动方式可使用：scripts/run_local_rag.sh
LOCAL_RAG_DB_PATH=storage/local_rag/local_rag.sqlite3
LOCAL_RAG_EMBEDDING_PROVIDER=hash
LOCAL_RAG_EMBEDDING_URL=
LOCAL_RAG_EMBEDDING_MODEL=
LOCAL_RAG_EMBEDDING_MODEL_PATH=
LOCAL_RAG_EMBEDDING_API_KEY=
LOCAL_RAG_EMBEDDING_DIMENSION=64
LOCAL_RAG_EMBEDDING_DEVICE=auto
LOCAL_RAG_EMBEDDING_BATCH_SIZE=16
LOCAL_RAG_RERANK_PROVIDER=embedding_cosine
LOCAL_RAG_RERANK_MODEL=BAAI/bge-reranker-base
LOCAL_RAG_RERANK_MODEL_PATH=
LOCAL_RAG_RERANK_DEVICE=auto
LOCAL_RAG_RERANK_BATCH_SIZE=8
LOCAL_RAG_RERANK_UPSTREAM_URL=
LOCAL_RAG_RERANK_UPSTREAM_API_KEY=
LOCAL_RAG_RERANK_UPSTREAM_MODEL=
LOCAL_RAG_TORCH_NUM_THREADS=1
LOCAL_RAG_ALLOW_DEGRADED_FALLBACK=true
LOCAL_RAG_PRELOAD_MODELS=false
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat
SCENE_CONFIRMATION_SECRET=
